{
  "name": "trabalho-final-cicd",
  "version": "1.0.0",
  "private": true,
  "description": "Aplicação NestJS MVC do trabalho final de CI/CD.",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node src/main.ts",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "format": "prettier --write \"{src,test,views}/**/*.{ts,hbs}\" \".github/**/*.yml\" \"*.{json,md,yml}\"",
    "format:check": "prettier --check \"{src,test,views}/**/*.{ts,hbs}\" \".github/**/*.yml\" \"*.{json,md,yml}\"",
    "test": "jest --config jest.config.js --runInBand",
    "test:e2e": "jest --config jest-e2e.config.js --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "11.1.6",
    "@nestjs/core": "11.1.6",
    "@nestjs/platform-express": "11.1.6",
    "express-handlebars": "8.0.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "9.35.0",
    "@nestjs/testing": "11.1.6",
    "@types/express": "5.0.3",
    "@types/jest": "30.0.0",
    "@types/node": "24.3.0",
    "@types/supertest": "6.0.3",
    "eslint": "9.35.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "16.3.0",
    "jest": "30.1.3",
    "prettier": "3.6.2",
    "supertest": "7.1.4",
    "ts-jest": "29.4.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.2",
    "typescript-eslint": "8.42.0"
  }
}
